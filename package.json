{
  "name": "@l69d/omnicode",
  "version": "0.2.0",
  "description": "A model-agnostic agentic coding CLI — like Claude Code, but plug in any model (Claude, GPT, Gemini, DeepSeek, Groq, local Ollama, or any OpenAI-compatible endpoint).",
  "type": "module",
  "bin": {
    "omnicode": "dist/cli.js",
    "omni": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "coding-agent",
    "claude",
    "openai",
    "gemini",
    "deepseek",
    "ollama",
    "llm"
  ],
  "author": "Karthik Gowda",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/l69d/omnicode.git"
  },
  "homepage": "https://github.com/l69d/omnicode#readme",
  "bugs": {
    "url": "https://github.com/l69d/omnicode/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2",
    "@ai-sdk/google": "^2",
    "@ai-sdk/openai": "^2",
    "@ai-sdk/openai-compatible": "^1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^5",
    "ollama-ai-provider-v2": "^1",
    "picocolors": "^1.1.1",
    "zod": "^4.0.16"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
